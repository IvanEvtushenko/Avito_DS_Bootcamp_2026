# Artifacts are regenerated from data + config; never committed (see §5.1.6).
artifacts/
!artifacts/.gitkeep
# изолированные каталоги ablation-экспериментов (напр. lexical_only, artifacts_rr_*).
# ВАЖНО: комментарий — только на отдельной строке; инлайн-# в .gitignore ломает паттерн.
artifacts_*/
# архивы весов моделей (гигабайты) — не в git
model_archives/
*.tar.zst
*.safetensors

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling
.pytest_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
